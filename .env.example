APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ENV_VALIDATION_ENABLED=false
LANDLORD_DOMAIN=localhost
CENTRAL_DOMAINS=127.0.0.1,localhost
LOCAL_DOMAIN_AUTO_ADD=true
LOCAL_DOMAIN_IP=127.0.0.1
LOCAL_HOSTS_PATH=
CPANEL_DOMAIN_AUTO_ADD=false
CPANEL_HOST=
CPANEL_PORT=2083
CPANEL_USERNAME=
CPANEL_TOKEN=
CPANEL_DOCUMENT_ROOT=public_html
CPANEL_SSL_VERIFY=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=isp_management
DB_USERNAME=root
DB_PASSWORD=
TENANT_DB_PREFIX=tenant_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=isp-os-uploads
AWS_URL=
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_BUCKET_UPLOADS=isp-os-uploads
MINIO_BUCKET_EXPORTS=isp-os-exports
MINIO_BUCKET_BACKUPS=isp-os-backups
TENANT_UPLOAD_PREFIX=uploads/{tenant_id}

JWT_ISSUER="${APP_URL}"
JWT_SECRET=
JWT_TTL_MINUTES=43200

# AI chatbot (Tier 2/3) - Tier 1 (local KB) works with neither of these set.
GROQ_API_KEY=
GEMINI_API_KEY=

VITE_APP_NAME="${APP_NAME}"
